---
import Base from '../layouts/Base.astro';
import { SITE } from '../data/site';

const links = [
  ['/', 'หน้าแรก'],
  ['/services', 'บริการทั้งหมด'],
  ['/fleet', 'รถและเครื่องจักร'],
  ['/works', 'ผลงาน'],
  ['/blog', 'บทความ'],
  ['/contact', 'ติดต่อเรา'],
];
---

<Base
  title="ไม่พบหน้าที่ค้นหา (404) | ภูเก็ตนักยก"
  description="ไม่พบหน้าที่ค้นหา หน้านี้อาจย้ายหรือไม่มีแล้ว กลับไปหน้าแรกหรือดูบริการเช่าเครน แบคโฮ รถเฮี๊ยบ ตู้คอนเทนเนอร์ และรับรื้อถอนของภูเก็ตนักยก"
>
  <section class="page-hero">
    <div class="container">
      <h1>ไม่พบหน้าที่ค้นหา</h1>
      <p>หน้านี้อาจถูกย้ายหรือไม่มีแล้ว — ลองเลือกจากเมนูด้านล่าง</p>
    </div>
  </section>

  <section class="section" style="text-align:center;max-width:760px">
    <div style="font-family:'Prompt',sans-serif;font-weight:800;font-size:72px;color:var(--amber);line-height:1">404</div>
    <p style="color:var(--gray);font-size:17px;margin:12px 0 28px">
      เว็บภูเก็ตนักยกปรับปรุงใหม่ ลิงก์เก่าบางหน้าอาจเปลี่ยน ลองไปที่หน้าเหล่านี้:
    </p>
    <div class="notfound-links">
      {links.map(([href, label]) => (
        <a href={href} class="btn btn-amber btn-sm">{label}</a>
      ))}
    </div>
  </section>

  <section class="cta">
    <h2>ต้องการเช่าเครื่องจักรหรือปรึกษางาน?</h2>
    <p>โทรหรือทัก LINE ได้ทุกวัน ประเมินหน้างานฟรี</p>
    <div class="actions">
      <a href={`tel:${SITE.phone}`} class="btn btn-amber">📞 {SITE.phoneDisplay}</a>
      <a href={SITE.lineUrl} class="btn btn-ghost-line">💬 LINE: {SITE.lineId}</a>
    </div>
  </section>
</Base>
