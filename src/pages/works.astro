---
import Base from '../layouts/Base.astro';
import { SITE } from '../data/site';
import { demolitionWorks, generalWorks } from '../data/works';

const groups = [
  {
    heading: 'รับรื้อถอน ทุบตึก รื้อบ้าน เคลียร์พื้นที่',
    sub: 'งานรื้อถอนโครงสร้าง ทุบตึก รื้อบ้าน เคลียร์พื้นที่ พร้อมขนวัสดุไปทิ้ง',
    alt: 'ผลงานรับรื้อถอน ทุบตึก เคลียร์พื้นที่',
    photos: demolitionWorks,
  },
  {
    heading: 'งานยก ขนส่ง ถมที่ ทั่วภูเก็ต',
    sub: 'งานเครน รถ 6 ล้อติดเครน แบคโฮ ตู้คอนเทนเนอร์ และงานถมที่',
    alt: 'ผลงานงานยก ขนส่ง ถมที่ ภูเก็ต',
    photos: generalWorks,
  },
];
const total = demolitionWorks.length + generalWorks.length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: 'ผลงานของเรา — ภูเก็ตนักยก',
      url: `${SITE.url}/works`,
      description: 'ตัวอย่างผลงานจริง รับรื้อถอน ทุบตึก งานยกเครน รถเฮี๊ยบ แบคโฮ ตู้คอนเทนเนอร์ และงานถมที่ ทั่วภูเก็ต',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'ผลงาน', item: `${SITE.url}/works` },
      ],
    },
  ],
};
---

<Base
  title="ผลงานของเรา - รับรื้อถอน งานยก งานถม ทั่วภูเก็ต | ภูเก็ตนักยก"
  description={`รวมผลงานจริงของภูเก็ตนักยก ${total}+ งาน รับรื้อถอน ทุบตึก เคลียร์พื้นที่ งานยกเครน รถเฮี๊ยบ แบคโฮ ตู้คอนเทนเนอร์ และงานถมที่ ทั่วภูเก็ต`}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <h1>ผลงานของเรา</h1>
      <p>รวมงานจริงจากหน้างาน รับรื้อถอน งานยก งานขุด งานถม</p>
    </div>
  </section>

  <section class="section">
    <p style="max-width:820px;color:#5C5C5C;line-height:1.8;margin:0 0 32px">
      รวมตัวอย่างผลงานจริงกว่า {total} งานของภูเก็ตนักยก ครอบคลุมงานรับรื้อถอน ทุบตึก เคลียร์พื้นที่ งานยกติดตั้งด้วยเครนและรถเฮี๊ยบ งานขุด-ถมด้วยแบคโฮ และงานติดตั้งตู้คอนเทนเนอร์ ทั่วจังหวัดภูเก็ตและพื้นที่ใกล้เคียง คลิกที่รูปเพื่อดูภาพเต็ม
    </p>
    {groups.map((g) => (
      <div class="gallery-group">
        <h2>{g.heading}</h2>
        <p class="gallery-sub">{g.sub}</p>
        <div class="gallery-grid">
          {g.photos.map((src, i) => (
            <a href={src} target="_blank" rel="noopener" class="gallery-item" aria-label={`${g.alt} ${i + 1}`}>
              <img src={src} alt={`${g.alt} ${i + 1}`} loading="lazy" />
            </a>
          ))}
        </div>
      </div>
    ))}
    <p style="text-align:center;color:#767676;margin-top:8px;font-size:15px">
      ติดตามผลงานเพิ่มเติมได้ที่ <a href={SITE.facebook}>Facebook: ภูเก็ตนักยก</a>
    </p>
  </section>

  <section class="cta">
    <h2>มีงานรื้อถอน งานยก งานถม?</h2>
    <p>โทรปรึกษาฟรี ประเมินหน้างาน เสนอราคาไว</p>
    <div class="actions">
      <a href={`tel:${SITE.phone}`} class="btn btn-amber">📞 {SITE.phoneDisplay}</a>
      <a href={SITE.lineUrl} class="btn btn-ghost-line">💬 LINE: {SITE.lineId}</a>
    </div>
  </section>
</Base>
